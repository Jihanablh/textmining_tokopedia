        "all_reviews = []\n",
        "continuation_token = None\n",
        "\n",
        "progress_bar = tqdm(total=total_reviews, desc=\"Mengambil Reviews\")\n",
        "\n",
        "while len(all_reviews) < total_reviews:\n",
        "    remaining = total_reviews - len(all_reviews)\n",
        "    current_batch_size = min(batch_size, remaining)\n",
        "\n",
        "    try:\n",
        "        result, continuation_token = reviews(\n",
        "            app_id,\n",
        "            lang=lang,\n",
        "            country=country,\n",
        "            sort=Sort.NEWEST,\n",
        "            count=current_batch_size,\n",
        "            continuation_token=continuation_token,\n",
        "        )\n",
        "    except Exception as error:\n",
        "        print(f\"Proses terhenti karena error: {error}\")\n",
        "        break\n",
        "\n",
        "    if not result:\n",
        "        print(\"Tidak ada lagi review yang bisa diambil.\")\n",
        "        break\n",
        "\n",
        "    all_reviews.extend(result)\n",
        "    progress_bar.update(len(result))\n",
        "\n",
        "    if continuation_token is None:\n",
        "        print(\"Tidak ada lagi token untuk melanjutkan.\")\n",
        "        break\n",
        "\n",
        "    time.sleep(sleep_time)\n",
        "\n",
        "progress_bar.close()\n",
        "print(\"Jumlah review berhasil diambil:\", len(all_reviews))"
      ]
