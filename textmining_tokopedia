        "def split_train_test(x_data, y_data, test_size):\n",
        "    try:\n",
        "        return train_test_split(\n",
        "            x_data,\n",
        "            y_data,\n",
        "            test_size=test_size,\n",
        "            random_state=42,\n",
        "            stratify=y_data,\n",
        "        )\n",
        "    except ValueError:\n",
        "        return train_test_split(\n",
        "            x_data,\n",
        "            y_data,\n",
