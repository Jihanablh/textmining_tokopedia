        "def kelompok_sentimen(rating):\n",
        "    if rating >= 4:\n",
        "        return \"Positif\"\n",
        "    if rating == 3:\n",
        "        return \"Netral\"\n",
        "    return \"Negatif\"\n",
        "\n",
        "df[\"sentiment_category\"] = df[\"rating\"].apply(kelompok_sentimen)\n",
        "df_sentiment = df[df[\"sentiment_category\"] != \"Netral\"].copy()\n",
        "\n",
        "df_sentiment.head()"
